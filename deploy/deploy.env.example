# Server connection
SERVER_HOST=********
SERVER_USER=root
SERVER_PORT=22
SSH_KEY_PATH=$HOME/.ssh/id_rsa

# Remote paths
REMOTE_TMP_DIR=/tmp
REMOTE_RELEASES_DIR=/srv/releases/vibecoding
REMOTE_WEB_ROOT=/srv/www

# Keep latest N releases on server
KEEP_RELEASES=5

# sudo command on remote host
# Use value "none" when logging in as root and no sudo is required.
REMOTE_SUDO_CMD=none
